{
  "_description": "L3 实体提取正则规则 - 用于从文本中自动提取候选专有名词",
  "_usage": "每条规则包含 pattern (正则表达式)、category (类别名)、base_score (基础分 0-100)",
  "_note": "正则中 group(1) 应为纯净实体名，前后缀由引擎自动清理",
  "patterns": [
    {
      "pattern": "([\\u4e00-\\u9fff]{1,3}(?:购|商城|超市|百货|优选|特卖|专营|官方店|旗舰店))",
      "category": "电商平台名",
      "base_score": 60
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff])([\\u4e00-\\u9fff]{2,6}(?:公司|集团|企业|科技|股份|有限|控股|投资|基金|银行|保险|证券|信托|事务所|工作室|中心|社|院|厂|局))",
      "category": "公司机构名",
      "base_score": 50
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff])([\\u4e00-\\u9fff]{2,6}(?:店|馆))",
      "category": "公司机构名（小后缀）",
      "base_score": 40
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff])([\\u4e00-\\u9fff]{2,5}(?:大学|学院|学校|研究院|研究所|实验室|医院|中心|协会|学会|组织))",
      "category": "学术机构名",
      "base_score": 45
    },
    {
      "pattern": "\\b([\\u4e00-\\u9fff]{2,5}(?:牌|系列|型号|版))\\b",
      "category": "产品品牌名",
      "base_score": 40
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff])([\\u4e00-\\u9fff]{2,6}(?:局|委员会|办公厅|管理处|监管局|指挥部|办公室))",
      "category": "政府机构名",
      "base_score": 48
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff])([\\u4e00-\\u9fff]{3,8}(?:行业协会|联合会|促进会|联盟|商会|公会))",
      "category": "行业组织名",
      "base_score": 45
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff])([\\u4e00-\\u9fff]{2,6}(?:微电子|半导体|集成电路|光电子))",
      "category": "半导体企业名",
      "base_score": 50
    },
    {
      "pattern": "([A-Z][A-Za-z0-9]*[-–][A-Z0-9][A-Za-z0-9]*)",
      "category": "产品型号",
      "base_score": 42
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff])([\\u4e00-\\u9fff]{2,3})(?:先生|女士|小姐|博士|教授|老师|工程师|经理|总监|总|董)",
      "category": "人名+称谓",
      "base_score": 35
    },
    {
      "pattern": "(?:^|[^\\u4e00-\\u9fff]|位于|在|于|至|往|从|的)([\\u4e00-\\u9fff]{2,4}(?:省|市|县|区|镇|乡|村|路|街|道|广场|大厦|写字楼|商场|机场|车站|港口))",
      "category": "地名",
      "base_score": 30
    },
    {
      "pattern": "[\"\\u300c\\u300d\\u201c\\u201d]([\\u4e00-\\u9fff]{2,10})(?:计划|行动|工程|倡议|战略|峰会|论坛|大会|博览会)[\"\\u300c\\u300d\\u201c\\u201d]",
      "category": "会议/IP名",
      "base_score": 32
    },
    {
      "pattern": "[\"\\u300c\\u300d\\u201c\\u201d]([\\u4e00-\\u9fff]{2,8})[\"\\u300c\\u300d\\u201c\\u201d]",
      "category": "引用名称/IP名",
      "base_score": 25
    },
    {
      "pattern": "\\b([A-Z][a-z]{2,}(?:[ -][A-Z][a-z]{2,}){1,2})(?: Inc| Corp| LLC| Ltd| Co| Group)?\\b",
      "category": "英文机构/品牌名",
      "base_score": 40
    },
    {
      "pattern": "\\b(\\d{17}[\\dXx])\\b",
      "category": "身份证号",
      "base_score": 65
    },
    {
      "pattern": "\\b(1[3-9]\\d{9})\\b",
      "category": "手机号",
      "base_score": 55
    },
    {
      "pattern": "\\b([\\w.+-]+@[\\w.-]+\\.[A-Za-z]{2,})\\b",
      "category": "邮箱地址",
      "base_score": 45
    },
    {
      "pattern": "(https?://[^\\s,。，]+)",
      "category": "URL",
      "base_score": 40
    },
    {
      "pattern": "\\b(\\d{16,19})\\b",
      "category": "银行卡号",
      "base_score": 60
    }
  ]
}
