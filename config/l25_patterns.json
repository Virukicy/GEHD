{
  "_description": "L2.5 非实体幻觉检测规则 - 覆盖统计数据、引述、时间线类幻觉",
  "_usage": "每条规则包含 pattern (正则)、category (类别)、base_score (基础分)",
  "patterns": [
    {
      "pattern": "(\\d+(?:\\.\\d+)?(?:万亿|亿|万)?(?:元|美元|人民币|欧元))",
      "category": "可疑统计金额",
      "base_score": 48
    },
    {
      "pattern": "(?:增长率?|增速|增幅|涨幅|同比|环比|市占率?|占有率|渗透率|转化率|复购率)[超达]?\\s*(\\d+(?:\\.\\d+)?%)",
      "category": "可疑百分比数据",
      "base_score": 45
    },
    {
      "pattern": "(?<!已)(?<!完成)(?:达|约|将近|超过|突破)\\s*(\\d+(?:\\.\\d+)?(?:万亿|亿|万)?\\s*(?:元|美元|人|户|家|台|套))",
      "category": "可疑规模描述",
      "base_score": 42
    },
    {
      "pattern": "据\\s*([\\u4e00-\\u9fff]{2,4}(?:教授|博士|院士|CEO|总裁|总[经理裁]|部长|司长|局长|主任|所长))\\s*(?:称|表示|透露|指出|强调|透露|宣布)",
      "category": "权威引述",
      "base_score": 50
    },
    {
      "pattern": "[\"\\u201c]((?:(?:[\\u4e00-\\u9fff]{1,3}(?:教授|博士|院士|CEO|总裁|总[经理裁]|部长|司长|局长|主任|所长|先生|女士))|(?:[\\u4e00-\\u9fff]{2,6}(?:公司|集团|研究院|研究所|大学|学院|银行|部委|协会|学会))|(?:\\d+(?:\\.\\d+)?(?:%|(?:万亿|亿|万)?(?:元|美元|人|家)))|(?:20\\d{2}年|[一二三四]季度|Q[1-4]|[上下本]月|今年|去年|前年)).{0,50}[^\"\\u201d]{5,})[\"\\u201d]",
      "category": "直接引语(待核实)",
      "base_score": 35
    },
    {
      "pattern": "(?:于|在|预计|将于|将在|计划于)\\s*(20\\d{2}年(?:[一二三四]?季度|Q[1-4]|[1-12]月))",
      "category": "时间线引用",
      "base_score": 38
    },
    {
      "pattern": "(?:已于?|已在|已经完成|已完成|成功实现)\\s*(20\\d{2}(?:年[1-12]月|[/-]\\d{1,2}))",
      "category": "完成时间声明",
      "base_score": 40
    },
    {
      "pattern": "(\\d+[亿万千]\\d+[万千]?\\s*(?:元|美元))",
      "category": "金额区间",
      "base_score": 42
    },
    {
      "pattern": "(\\d+[.-]\\d+%)",
      "category": "百分比范围",
      "base_score": 40
    }
  ]
}
